{
    "build": {
        "beforeBuildCommand": "pnpm build",
        "devPath": "http://localhost:1420",
        "distDir": "../dist"
    },
    "package": {
        "productName": "ymcl",
        "version": "0.0.0"
    },
    "tauri": {
        "allowlist": {
            "all": true
        },
        "windows": [
            {
                "title": "YunMCL",
                "width": 1440,
                "height": 1024,
                "minWidth": 1380,
                "minHeight": 920,
                "decorations": false,
                "transparent": true,
                "titleBarStyle": "Transparent"
            }
        ],
        "security": {
            "csp": null
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "lab.yuns.ymcl",
            "icon": [
                "icons/32x32.png",
                "icons/128x128.png",
                "icons/128x128@2x.png",
                "icons/icon.icns",
                "icons/icon.ico"
            ]
        }
    }
}
