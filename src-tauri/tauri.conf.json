{
    "build": {
        "devPath": "http://localhost:1420",
        "distDir": "../dist"
    },
    "package": {
        "productName": "yunmcl",
        "version": "0.0.0"
    },
    "tauri": {
        "allowlist": {
            "all": true,
            "fs": {
                "scope": ["$APPCACHE\\api_fetch\\*_version_manifest.json"]
            }
        },
        "windows": [
            {
                "title": "YunMCL",
                "width": 1280,
                "height": 770,
                "resizable": false,
                "center": true,
                "decorations": false,
                "transparent": true,
                "titleBarStyle": "Transparent"
            }
        ],
        "security": {
            "csp": null
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "lab.yuns.ymcl",
            "icon": [
                "icons/32x32.png",
                "icons/128x128.png",
                "icons/128x128@2x.png",
                "icons/icon.icns",
                "icons/icon.ico"
            ]
        }
    }
}
